# Which database driver this instance should use: "postgres" or "mssql"
DB_TYPE=postgres

# Used when DB_TYPE=postgres (local Docker Postgres for testing)
DATABASE_URL=postgresql://user:password@localhost:5432/eventdb

# Used when DB_TYPE=mssql (Azure SQL Database) — not needed for local testing
DB_SERVER=your-azure-sql-server.database.windows.net
DB_NAME=eventdb
DB_USER=your-username
DB_PASSWORD=your-password

# User registration/login is NOT implemented as a local Next.js API route
# (deliberate scope decision - see README). The frontend calls a deployed
# cloud endpoint directly for these. Point this at either your AWS API
# Gateway URL or your Azure Function App URL (include /api for Azure).
NEXT_PUBLIC_API_BASE_URL=https://l30myjhqlk.execute-api.ap-southeast-1.amazonaws.com
